# Production environment for the parking system.
#
#   cp deploy/.env.production.example deploy/.env.production
#   # then edit the REQUIRED values below
#
# deploy/.env.production is git-ignored and read by ./pipeline.sh. Never commit
# real secrets. Rotate JWT_SECRET and POSTGRES_PASSWORD before go-live.

# ─── REQUIRED ──────────────────────────────────────────────────────────────

# Token signing secret. MUST be a strong random value of >= 16 chars, or the
# backend refuses to boot (APP_ENV=production). Generate one with:
#   openssl rand -hex 32
JWT_SECRET=

# Public origin(s) the browser will load the app from, comma-separated, no
# trailing slash. Example: https://parking.example.gov.tw
CORS_ALLOW_ORIGINS=

# PostgreSQL credentials for the bundled db service.
POSTGRES_USER=parking
POSTGRES_PASSWORD=
POSTGRES_DB=parking

# ─── OPTIONAL (sensible defaults shown) ─────────────────────────────────────

# Host port the public nginx frontend listens on. Put a TLS-terminating
# reverse proxy in front of this in a real deployment.
FRONTEND_PORT=8080

# Image tag applied to the built backend/frontend images (set automatically by
# `./pipeline.sh build-production`; usually the promoted git short SHA).
TAG=latest

# Real external QR query-site host allow-list (SSRF guard). Leave empty to keep
# real QR fetching disabled. Example: qrquery.example.gov.tw
QR_QUERY_ALLOWED_HOSTS=

# Session length and login throttle.
JWT_EXPIRE_MINUTES=720
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
LOGIN_LOCKOUT_SECONDS=300

# Max accepted photo upload size in bytes (default 8 MiB).
MAX_UPLOAD_BYTES=8388608
