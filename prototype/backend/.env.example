# Copy to .env (or export these in your shell / orchestrator) for a real
# deployment. docker-compose.yml reads JWT_SECRET from the host environment.

# ---- Security (required in production) ----
# Long random string used to sign JWT access tokens. Generate with e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
# Access-token lifetime in minutes (default 720 = 12h).
JWT_EXPIRE_MINUTES=720

# ---- Database ----
# SQLAlchemy URL. PostgreSQL for real deployments:
DATABASE_URL=postgresql+psycopg2://parking:parking@db:5432/parking
# For a quick local SQLite run instead, leave DATABASE_URL unset (the app
# defaults to a local sqlite file) or use:
#   DATABASE_URL=sqlite:///./parking.db

# ---- CORS ----
# Comma-separated allow-list of browser origins permitted to call the API.
# No wildcard. Include every origin the frontend is served from.
CORS_ALLOW_ORIGINS=http://localhost:8080

# ---- Uploads ----
# Where captured photos are written.
PARKING_UPLOADS_DIR=/app/data/uploads
