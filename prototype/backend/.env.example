# Copy to .env (or export these in your shell / orchestrator) for a real
# deployment. docker-compose.yml reads JWT_SECRET from the host environment.

# ---- Environment ----
# Set to "production" for real deployments. In production the backend refuses
# to boot if JWT_SECRET is weak or a known placeholder (fail-fast). Defaults to
# "development", which only warns.
APP_ENV=production

# ---- Security (required in production) ----
# Long random string used to sign JWT access tokens (>= 16 chars; known
# placeholders are rejected in production). Generate with e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
# Access-token lifetime in minutes (default 720 = 12h).
JWT_EXPIRE_MINUTES=720

# ---- Login throttling ----
# After LOGIN_MAX_ATTEMPTS failed logins within LOGIN_WINDOW_SECONDS for a
# username/IP, further attempts are locked out for LOGIN_LOCKOUT_SECONDS.
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
LOGIN_LOCKOUT_SECONDS=300

# ---- Uploads ----
# Max accepted photo size in bytes (default 8 MiB). Larger uploads are
# rejected with HTTP 413 before touching disk.
MAX_UPLOAD_BYTES=8388608

# ---- Database ----
# SQLAlchemy URL. PostgreSQL for real deployments:
DATABASE_URL=postgresql+psycopg2://parking:parking@db:5432/parking
# For a quick local SQLite run instead, leave DATABASE_URL unset (the app
# defaults to a local sqlite file) or use:
#   DATABASE_URL=sqlite:///./parking.db

# ---- CORS ----
# Comma-separated allow-list of browser origins permitted to call the API.
# No wildcard. Include every origin the frontend is served from.
CORS_ALLOW_ORIGINS=http://localhost:8080

# ---- Uploads ----
# Where captured photos are written.
PARKING_UPLOADS_DIR=/app/data/uploads

# ---- QR query site ----
# The parking-ticket QR encodes a URL to an external query page that the
# backend fetches to auto-fill ticket data.
# Real fetching is DISABLED unless you list the query-site host(s) here
# (comma-separated). This is an SSRF guard: the backend will only fetch URLs
# whose host is on this allow-list. Leave empty in demo/dev to use the built-in
# demo codes only.
#   QR_QUERY_ALLOWED_HOSTS=qr.parking.example.gov.tw
QR_QUERY_ALLOWED_HOSTS=
# Resolve the built-in QR-A1001... demo codes without a network call.
QR_DEMO_MODE=true
# HTTP timeout (seconds) when fetching the query page.
QR_QUERY_TIMEOUT=5
# Serve a local stand-in query site at /mock-qr-site/{token} for demoing the
# real fetch path without a live endpoint. Turn OFF in production.
QR_MOCK_SITE_ENABLED=true
